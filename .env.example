# ── API backend ───────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# In production, set this to your dashboard domain (no trailing slash).
# Example: https://ops.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Seconds before a service file is considered stale in /health/services.
# Default: 3600 (1 hour). Tune per component in production.
SERVICE_STALE_SECONDS=3600

# SGD cost per zone requiring an intervention (used in cost estimates).
INTERVENTION_COST_PER_ZONE=1.50


# ── AI chat ───────────────────────────────────────────────────────────────────

# Anthropic API key — required for /api/v1/ai/chat to return real AI responses.
# Without this, the endpoint returns the assembled ops context as a plain-text
# reply so you can verify the prompt is wired up correctly.
ANTHROPIC_API_KEY=

# Claude model to use for the ops AI chat endpoint.
# Defaults to claude-haiku-4-5-20251001 (fast, low cost).
# Use claude-sonnet-4-6 for better reasoning on complex ops questions.
AI_MODEL=claude-haiku-4-5-20251001


# ── Data ingestion ────────────────────────────────────────────────────────────

# LTA DataMall API key — required for live taxi snapshot polling.
# Register at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_API_KEY=


# ── Alerting ─────────────────────────────────────────────────────────────────

# Optional Slack/webhook URL to receive alert notifications.
# Leave blank to disable webhook delivery.
ALERT_WEBHOOK_URL=


# ── Frontend (set at Vite build time) ─────────────────────────────────────────

# API base URL for the React frontend.
# Leave unset to use relative /api/v1 (works behind a reverse proxy).
# Set explicitly for non-proxy deployments: http://your-api-server:8000/api/v1
# VITE_API_BASE_URL=/api/v1
